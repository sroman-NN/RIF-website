.section rom
start:
sei
cld
ldx 0xff
txs
lda 0x00
sta 0x01

main:
lda 0x02
sta 0x00
sta 0x02
sta 0x02
sta 0x02
lda 0x00
sta 0x00

ldx 37
vblank:
sta 0x02
dex
bne vblank

lda 0xc8
sta 0x09
ldx 192
visible:
sta 0x02
dex
bne visible

lda 0x02
sta 0x01
ldx 30
overscan:
sta 0x02
dex
bne overscan
lda 0x00
sta 0x01
jmp main

rompad_to_vectors
vectors start
