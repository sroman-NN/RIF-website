comment ;
blocks :
table-separator |
encoding utf-8

.pack

plugin "basics"
plugin "megadrive"
pluginsymbolorder 0

types:
    from ".regs" as REG
    from ".types" as TYPE

packer:
    entryfilename "main"
    ext ".mdasm"
    outext ".bin"
    filesystem 1
    subpre *
    setpre regs .regs
    setpre rules .rules
    setpre sections .sections
    setpre types .types
    setpre words .words

linker:
    filesystem 1
    sectexec .rom
    sectopt .ram
    sectopt .z80_ram

reader:
    comment ";"
    separator "|"
    blocks ":"
    section ".section"

.DATA_DEFINITION
    arrautofill true
    supportstring true

.world
    endianness big
