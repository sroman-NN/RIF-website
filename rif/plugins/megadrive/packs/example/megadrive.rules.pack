; ============================================================
; Megadrive / Motorola 68000 Rules Pack
; Full instruction encoding for RIF assembler
; Big-endian architecture - 16-bit word aligned
; ============================================================

; ============================================================
; NOP
; ============================================================
nop:
    emit 0100111001110001

; ============================================================
; MOVE instructions
; ============================================================

; MOVE.B #imm, Dn
move_b_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0001000000111100
    emit _imm8

; MOVE.W #imm, Dn
move_w_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 0011000000111100
    emit _imm16

; MOVE.L #imm, Dn
move_l_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 32
    zext _imm32, imm.binary, 32
    emit 0010000000111100
    emit _imm32

; MOVE.B Dn, Dm
move_b_d_d:
    need REG, src
    need REG, dst
    emit 0001000000000000

; MOVE.W Dn, Dm
move_w_d_d:
    need REG, src
    need REG, dst
    emit 0011000000000000

; MOVE.L Dn, Dm
move_l_d_d:
    need REG, src
    need REG, dst
    emit 0010000000000000

; MOVE.B #imm, (abs).l
move_b_imm_mem:
    need VALUE, imm
    need VALUE, addr
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    bitfit addr.binary, 32
    zext _addr32, addr.binary, 32
    emit 0001000111111001
    emit _imm8
    emit _addr32

; MOVE.W #imm, (abs).l
move_w_imm_mem:
    need VALUE, imm
    need VALUE, addr
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    bitfit addr.binary, 32
    zext _addr32, addr.binary, 32
    emit 0011000111111001
    emit _imm16
    emit _addr32

; MOVE.L #imm, (abs).l
move_l_imm_mem:
    need VALUE, imm
    need VALUE, addr
    bitfit imm.binary, 32
    zext _imm32, imm.binary, 32
    bitfit addr.binary, 32
    zext _addr32, addr.binary, 32
    emit 0010000111111001
    emit _imm32
    emit _addr32

; MOVE.B Dn, (abs).l
move_b_d_mem:
    need REG, src
    need VALUE, addr
    bitfit addr.binary, 32
    zext _addr32, addr.binary, 32
    emit 0001000111000000
    emit _addr32

; MOVE.W Dn, (abs).l
move_w_d_mem:
    need REG, src
    need VALUE, addr
    bitfit addr.binary, 32
    zext _addr32, addr.binary, 32
    emit 0011000111000000
    emit _addr32

; MOVE.L Dn, (abs).l
move_l_d_mem:
    need REG, src
    need VALUE, addr
    bitfit addr.binary, 32
    zext _addr32, addr.binary, 32
    emit 0010000111000000
    emit _addr32

; MOVE.B (abs).l, Dn
move_b_mem_d:
    need VALUE, addr
    need REG, dst
    bitfit addr.binary, 32
    zext _addr32, addr.binary, 32
    emit 0001000000111001
    emit _addr32

; MOVE.W (abs).l, Dn
move_w_mem_d:
    need VALUE, addr
    need REG, dst
    bitfit addr.binary, 32
    zext _addr32, addr.binary, 32
    emit 0011000000111001
    emit _addr32

; MOVE.L (abs).l, Dn
move_l_mem_d:
    need VALUE, addr
    need REG, dst
    bitfit addr.binary, 32
    zext _addr32, addr.binary, 32
    emit 0010000000111001
    emit _addr32

; MOVE.W Dn, An
move_w_d_a:
    need REG, src
    need REG, dst
    emit 0011000001000000

; MOVE.L Dn, An
move_l_d_a:
    need REG, src
    need REG, dst
    emit 0010000001000000

; MOVE.W An, Dn
move_w_a_d:
    need REG, src
    need REG, dst
    emit 0011000001001000

; MOVE.L An, Dn
move_l_a_d:
    need REG, src
    need REG, dst
    emit 0010000001001000

; MOVE.W #imm, An
move_w_imm_a:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 0011000001111100
    emit _imm16

; MOVE.L #imm, An
move_l_imm_a:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 32
    zext _imm32, imm.binary, 32
    emit 0010000001111100
    emit _imm32

; MOVEA.W Dn, An
movea_w_d:
    need REG, src
    need REG, dst
    emit 0011000001000000

; MOVEA.L Dn, An
movea_l_d:
    need REG, src
    need REG, dst
    emit 0010000001000000

; MOVEA.W #imm, An
movea_w_imm:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 0011000001111100
    emit _imm16

; MOVEA.L #imm, An
movea_l_imm:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 32
    zext _imm32, imm.binary, 32
    emit 0010000001111100
    emit _imm32

; MOVEQ #data8, Dn
moveq:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0111000000000000
    emit _imm8

; ============================================================
; ADD instructions
; ============================================================

add_b_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 1101000000111100
    emit _imm8

add_w_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 1101000001111100
    emit _imm16

add_l_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 32
    zext _imm32, imm.binary, 32
    emit 1101000010111100
    emit _imm32

add_b_d_d:
    need REG, src
    need REG, dst
    emit 1101000000000000

add_w_d_d:
    need REG, src
    need REG, dst
    emit 1101000001000000

add_l_d_d:
    need REG, src
    need REG, dst
    emit 1101000010000000

adda_w_d:
    need REG, src
    need REG, dst
    emit 1101000001000000

adda_l_d:
    need REG, src
    need REG, dst
    emit 1101000010000000

adda_w_imm:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 1101000001111100
    emit _imm16

adda_l_imm:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 32
    zext _imm32, imm.binary, 32
    emit 1101000010111100
    emit _imm32

addi_b:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0000011000000000
    emit _imm8

addi_w:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 0000011001000000
    emit _imm16

addi_l:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 32
    zext _imm32, imm.binary, 32
    emit 0000011010000000
    emit _imm32

addq_b:
    need VALUE, imm
    need REG, dst
    emit 0101000000000000

addq_w:
    need VALUE, imm
    need REG, dst
    emit 0101000001000000

addq_l:
    need VALUE, imm
    need REG, dst
    emit 0101000010000000

addx_b_d_d:
    need REG, src
    need REG, dst
    emit 1101000100000000

addx_w_d_d:
    need REG, src
    need REG, dst
    emit 1101000101000000

addx_l_d_d:
    need REG, src
    need REG, dst
    emit 1101000110000000

; ============================================================
; SUB instructions
; ============================================================

sub_b_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 1001000000111100
    emit _imm8

sub_w_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 1001000001111100
    emit _imm16

sub_l_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 32
    zext _imm32, imm.binary, 32
    emit 1001000010111100
    emit _imm32

sub_b_d_d:
    need REG, src
    need REG, dst
    emit 1001000000000000

sub_w_d_d:
    need REG, src
    need REG, dst
    emit 1001000001000000

sub_l_d_d:
    need REG, src
    need REG, dst
    emit 1001000010000000

suba_w_d:
    need REG, src
    need REG, dst
    emit 1001000001000000

suba_l_d:
    need REG, src
    need REG, dst
    emit 1001000010000000

suba_w_imm:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 1001000001111100
    emit _imm16

suba_l_imm:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 32
    zext _imm32, imm.binary, 32
    emit 1001000010111100
    emit _imm32

subi_b:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0000010000000000
    emit _imm8

subi_w:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 0000010001000000
    emit _imm16

subi_l:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 32
    zext _imm32, imm.binary, 32
    emit 0000010010000000
    emit _imm32

subq_b:
    need VALUE, imm
    need REG, dst
    emit 0101000100000000

subq_w:
    need VALUE, imm
    need REG, dst
    emit 0101000101000000

subq_l:
    need VALUE, imm
    need REG, dst
    emit 0101000110000000

subx_b_d_d:
    need REG, src
    need REG, dst
    emit 1001000100000000

subx_w_d_d:
    need REG, src
    need REG, dst
    emit 1001000101000000

subx_l_d_d:
    need REG, src
    need REG, dst
    emit 1001000110000000

; ============================================================
; NEG / NEGX
; ============================================================

neg_b:
    need REG, dst
    emit 0100010000000000

neg_w:
    need REG, dst
    emit 0100010001000000

neg_l:
    need REG, dst
    emit 0100010010000000

negx_b:
    need REG, dst
    emit 0100000000000000

negx_w:
    need REG, dst
    emit 0100000001000000

negx_l:
    need REG, dst
    emit 0100000010000000

; ============================================================
; MUL / DIV
; ============================================================

mulu_w_d_d:
    need REG, src
    need REG, dst
    emit 1100000011000000

muls_w_d_d:
    need REG, src
    need REG, dst
    emit 1100000111000000

mulu_w_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 1100000011111100
    emit _imm16

muls_w_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 1100000111111100
    emit _imm16

divu_w_d_d:
    need REG, src
    need REG, dst
    emit 1000000011000000

divs_w_d_d:
    need REG, src
    need REG, dst
    emit 1000000111000000

divu_w_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 1000000011111100
    emit _imm16

divs_w_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 1000000111111100
    emit _imm16

; ============================================================
; AND instructions
; ============================================================

and_b_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 1100000000111100
    emit _imm8

and_w_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 1100000001111100
    emit _imm16

and_l_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 32
    zext _imm32, imm.binary, 32
    emit 1100000010111100
    emit _imm32

and_b_d_d:
    need REG, src
    need REG, dst
    emit 1100000000000000

and_w_d_d:
    need REG, src
    need REG, dst
    emit 1100000001000000

and_l_d_d:
    need REG, src
    need REG, dst
    emit 1100000010000000

andi_b:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0000001000000000
    emit _imm8

andi_w:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 0000001001000000
    emit _imm16

andi_l:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 32
    zext _imm32, imm.binary, 32
    emit 0000001010000000
    emit _imm32

andi_to_ccr:
    need VALUE, imm
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0000001000111100
    emit _imm8

andi_to_sr:
    need VALUE, imm
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 0000001001111100
    emit _imm16

; ============================================================
; OR instructions
; ============================================================

or_b_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 1000000000111100
    emit _imm8

or_w_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 1000000001111100
    emit _imm16

or_l_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 32
    zext _imm32, imm.binary, 32
    emit 1000000010111100
    emit _imm32

or_b_d_d:
    need REG, src
    need REG, dst
    emit 1000000000000000

or_w_d_d:
    need REG, src
    need REG, dst
    emit 1000000001000000

or_l_d_d:
    need REG, src
    need REG, dst
    emit 1000000010000000

ori_b:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0000000000000000
    emit _imm8

ori_w:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 0000000001000000
    emit _imm16

ori_l:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 32
    zext _imm32, imm.binary, 32
    emit 0000000010000000
    emit _imm32

ori_to_ccr:
    need VALUE, imm
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0000000000111100
    emit _imm8

ori_to_sr:
    need VALUE, imm
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 0000000001111100
    emit _imm16

; ============================================================
; EOR instructions
; ============================================================

eor_b_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 1011000100111100
    emit _imm8

eor_w_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 1011000101111100
    emit _imm16

eor_l_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 32
    zext _imm32, imm.binary, 32
    emit 1011000110111100
    emit _imm32

eor_b_d_d:
    need REG, src
    need REG, dst
    emit 1011000100000000

eor_w_d_d:
    need REG, src
    need REG, dst
    emit 1011000101000000

eor_l_d_d:
    need REG, src
    need REG, dst
    emit 1011000110000000

eori_b:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0000101000000000
    emit _imm8

eori_w:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 0000101001000000
    emit _imm16

eori_l:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 32
    zext _imm32, imm.binary, 32
    emit 0000101010000000
    emit _imm32

eori_to_ccr:
    need VALUE, imm
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0000101000111100
    emit _imm8

eori_to_sr:
    need VALUE, imm
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 0000101001111100
    emit _imm16

; ============================================================
; NOT
; ============================================================

not_b:
    need REG, dst
    emit 0100011000000000

not_w:
    need REG, dst
    emit 0100011001000000

not_l:
    need REG, dst
    emit 0100011010000000

; ============================================================
; Shift / Rotate instructions
; ============================================================

asl_b_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000100000000

asl_w_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000101000000

asl_l_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000110000000

asl_b_d_d:
    need REG, src
    need REG, dst
    emit 1110000100100000

asl_w_d_d:
    need REG, src
    need REG, dst
    emit 1110000101100000

asl_l_d_d:
    need REG, src
    need REG, dst
    emit 1110000110100000

asr_b_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000000000000

asr_w_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000001000000

asr_l_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000010000000

asr_b_d_d:
    need REG, src
    need REG, dst
    emit 1110000000100000

asr_w_d_d:
    need REG, src
    need REG, dst
    emit 1110000001100000

asr_l_d_d:
    need REG, src
    need REG, dst
    emit 1110000010100000

lsl_b_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000100001000

lsl_w_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000101001000

lsl_l_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000110001000

lsl_b_d_d:
    need REG, src
    need REG, dst
    emit 1110000100101000

lsl_w_d_d:
    need REG, src
    need REG, dst
    emit 1110000101101000

lsl_l_d_d:
    need REG, src
    need REG, dst
    emit 1110000110101000

lsr_b_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000000001000

lsr_w_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000001001000

lsr_l_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000010001000

lsr_b_d_d:
    need REG, src
    need REG, dst
    emit 1110000000101000

lsr_w_d_d:
    need REG, src
    need REG, dst
    emit 1110000001101000

lsr_l_d_d:
    need REG, src
    need REG, dst
    emit 1110000010101000

rol_b_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000100011000

rol_w_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000101011000

rol_l_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000110011000

rol_b_d_d:
    need REG, src
    need REG, dst
    emit 1110000100111000

rol_w_d_d:
    need REG, src
    need REG, dst
    emit 1110000101111000

rol_l_d_d:
    need REG, src
    need REG, dst
    emit 1110000110111000

ror_b_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000000011000

ror_w_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000001011000

ror_l_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000010011000

ror_b_d_d:
    need REG, src
    need REG, dst
    emit 1110000000111000

ror_w_d_d:
    need REG, src
    need REG, dst
    emit 1110000001111000

ror_l_d_d:
    need REG, src
    need REG, dst
    emit 1110000010111000

roxl_b_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000100010000

roxl_w_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000101010000

roxl_l_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000110010000

roxr_b_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000000010000

roxr_w_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000001010000

roxr_l_imm_d:
    need VALUE, imm
    need REG, dst
    emit 1110000010010000

; ============================================================
; CMP / TST
; ============================================================

cmp_b_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 1011000000111100
    emit _imm8

cmp_w_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 1011000001111100
    emit _imm16

cmp_l_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 32
    zext _imm32, imm.binary, 32
    emit 1011000010111100
    emit _imm32

cmp_b_d_d:
    need REG, src
    need REG, dst
    emit 1011000000000000

cmp_w_d_d:
    need REG, src
    need REG, dst
    emit 1011000001000000

cmp_l_d_d:
    need REG, src
    need REG, dst
    emit 1011000010000000

cmpa_w_d:
    need REG, src
    need REG, dst
    emit 1011000011000000

cmpa_l_d:
    need REG, src
    need REG, dst
    emit 1011000111000000

cmpi_b:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0000110000000000
    emit _imm8

cmpi_w:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 0000110001000000
    emit _imm16

cmpi_l:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 32
    zext _imm32, imm.binary, 32
    emit 0000110010000000
    emit _imm32

cmpm_b:
    need REG, src
    need REG, dst
    emit 1011000100001000

cmpm_w:
    need REG, src
    need REG, dst
    emit 1011000101001000

cmpm_l:
    need REG, src
    need REG, dst
    emit 1011000110001000

tst_b:
    need REG, dst
    emit 0100101000000000

tst_w:
    need REG, dst
    emit 0100101001000000

tst_l:
    need REG, dst
    emit 0100101010000000

; ============================================================
; Branch instructions
; ============================================================

bra:
    need LABEL, target
    emit 01100000
    reldis ., target, 8

bra_imm:
    need VALUE, imm
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0110000000000000
    emit _imm8

bsr:
    need LABEL, target
    emit 01100001
    reldis ., target, 8

bsr_imm:
    need VALUE, imm
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0110000100000000
    emit _imm8

beq:
    need LABEL, target
    emit 01100111
    reldis ., target, 8

beq_imm:
    need VALUE, imm
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0110011100000000
    emit _imm8

bne:
    need LABEL, target
    emit 01100110
    reldis ., target, 8

bne_imm:
    need VALUE, imm
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0110011000000000
    emit _imm8

blt:
    need LABEL, target
    emit 01101101
    reldis ., target, 8

blt_imm:
    need VALUE, imm
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0110110100000000
    emit _imm8

bgt:
    need LABEL, target
    emit 01101110
    reldis ., target, 8

bgt_imm:
    need VALUE, imm
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0110111000000000
    emit _imm8

ble:
    need LABEL, target
    emit 01101111
    reldis ., target, 8

ble_imm:
    need VALUE, imm
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0110111100000000
    emit _imm8

bge:
    need LABEL, target
    emit 01101100
    reldis ., target, 8

bge_imm:
    need VALUE, imm
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0110110000000000
    emit _imm8

bcs:
    need LABEL, target
    emit 01100101
    reldis ., target, 8

bcs_imm:
    need VALUE, imm
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0110010100000000
    emit _imm8

bcc:
    need LABEL, target
    emit 01100100
    reldis ., target, 8

bcc_imm:
    need VALUE, imm
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0110010000000000
    emit _imm8

bmi:
    need LABEL, target
    emit 01101011
    reldis ., target, 8

bmi_imm:
    need VALUE, imm
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0110101100000000
    emit _imm8

bpl:
    need LABEL, target
    emit 01101010
    reldis ., target, 8

bpl_imm:
    need VALUE, imm
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0110101000000000
    emit _imm8

bvs:
    need LABEL, target
    emit 01101001
    reldis ., target, 8

bvs_imm:
    need VALUE, imm
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0110100100000000
    emit _imm8

bvc:
    need LABEL, target
    emit 01101000
    reldis ., target, 8

bvc_imm:
    need VALUE, imm
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0110100000000000
    emit _imm8

bhi:
    need LABEL, target
    emit 01100010
    reldis ., target, 8

bhi_imm:
    need VALUE, imm
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0110001000000000
    emit _imm8

bls:
    need LABEL, target
    emit 01100011
    reldis ., target, 8

bls_imm:
    need VALUE, imm
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0110001100000000
    emit _imm8

; ============================================================
; DBcc - Decrement and Branch
; ============================================================

dbra:
    need REG, dn
    need LABEL, target
    emit 0101000111001000
    reldis ., target, 16

dbf:
    need REG, dn
    need LABEL, target
    emit 0101000111001000
    reldis ., target, 16

dbt:
    need REG, dn
    need LABEL, target
    emit 0101000011001000
    reldis ., target, 16

dbcc:
    need REG, dn
    need LABEL, target
    emit 0101010011001000
    reldis ., target, 16

dbcs:
    need REG, dn
    need LABEL, target
    emit 0101010111001000
    reldis ., target, 16

dbeq:
    need REG, dn
    need LABEL, target
    emit 0101011111001000
    reldis ., target, 16

dbne:
    need REG, dn
    need LABEL, target
    emit 0101011011001000
    reldis ., target, 16

dbge:
    need REG, dn
    need LABEL, target
    emit 0101110011001000
    reldis ., target, 16

dbgt:
    need REG, dn
    need LABEL, target
    emit 0101111011001000
    reldis ., target, 16

dble:
    need REG, dn
    need LABEL, target
    emit 0101111111001000
    reldis ., target, 16

dblt:
    need REG, dn
    need LABEL, target
    emit 0101110111001000
    reldis ., target, 16

dbmi:
    need REG, dn
    need LABEL, target
    emit 0101101111001000
    reldis ., target, 16

dbpl:
    need REG, dn
    need LABEL, target
    emit 0101101011001000
    reldis ., target, 16

dbvs:
    need REG, dn
    need LABEL, target
    emit 0101100111001000
    reldis ., target, 16

dbvc:
    need REG, dn
    need LABEL, target
    emit 0101100011001000
    reldis ., target, 16

dbhi:
    need REG, dn
    need LABEL, target
    emit 0101001011001000
    reldis ., target, 16

dbls:
    need REG, dn
    need LABEL, target
    emit 0101001111001000
    reldis ., target, 16

; ============================================================
; JMP / JSR / RTS / RTE / RTR
; ============================================================

jmp:
    need REG, an
    emit 0100111011010000

jmp_abs:
    need LABEL, target
    emit 0100111011111001
    reloc abs, target, 32

jsr:
    need REG, an
    emit 0100111010010000

jsr_abs:
    need LABEL, target
    emit 0100111010111001
    reloc abs, target, 32

rts:
    emit 0100111001110101

rte:
    emit 0100111001110011

rtr:
    emit 0100111001110111

; ============================================================
; TRAP / TRAPV / CHK / ILLEGAL
; ============================================================

trap:
    need VALUE, imm
    bitfit imm.binary, 4
    zext _imm4, imm.binary, 4
    emit 0100111001000000
    emit _imm4

trapv:
    emit 0100111001110110

chk_w_d_d:
    need REG, src
    need REG, dst
    emit 0100000110000000

illegal:
    emit 0100101011111100

; ============================================================
; EXG / EXT / CLR / SWAP / LINK / UNLK
; ============================================================

exg_d_d:
    need REG, src
    need REG, dst
    emit 1100000101000000

exg_a_a:
    need REG, src
    need REG, dst
    emit 1100000101001000

exg_d_a:
    need REG, src
    need REG, dst
    emit 1100000110001000

ext_w:
    need REG, dst
    emit 0100100010000000

ext_l:
    need REG, dst
    emit 0100100011000000

extb_l:
    need REG, dst
    emit 0100100111000000

clr_b:
    need REG, dst
    emit 0100001000000000

clr_w:
    need REG, dst
    emit 0100001001000000

clr_l:
    need REG, dst
    emit 0100001010000000

swap:
    need REG, dst
    emit 0100100001000000

link:
    need REG, an
    need VALUE, imm
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 0100111001010000
    emit _imm16

unlk:
    need REG, an
    emit 0100111001011000

; ============================================================
; PEA / LEA
; ============================================================

pea:
    need REG, an
    emit 0100100001010000

lea:
    need REG, src
    need REG, dst
    emit 0100000111010000

; ============================================================
; TAS / RESET / STOP
; ============================================================

tas_b:
    need REG, dst
    emit 0100101011000000

reset:
    emit 0100111001110000

stop:
    need VALUE, imm
    bitfit imm.binary, 16
    zext _imm16, imm.binary, 16
    emit 0100111001110010
    emit _imm16

; ============================================================
; MOVEM
; ============================================================

movem_w_push:
    need VALUE, mask
    need REG, an
    bitfit mask.binary, 16
    zext _mask16, mask.binary, 16
    emit 0100100010100000
    emit _mask16

movem_l_push:
    need VALUE, mask
    need REG, an
    bitfit mask.binary, 16
    zext _mask16, mask.binary, 16
    emit 0100100011100000
    emit _mask16

movem_w_pop:
    need REG, an
    need VALUE, mask
    bitfit mask.binary, 16
    zext _mask16, mask.binary, 16
    emit 0100110010011000
    emit _mask16

movem_l_pop:
    need REG, an
    need VALUE, mask
    bitfit mask.binary, 16
    zext _mask16, mask.binary, 16
    emit 0100110011011000
    emit _mask16

; ============================================================
; SR / CCR moves
; ============================================================

move_to_ccr:
    need REG, src
    emit 0100010011000000

move_from_ccr:
    need REG, dst
    emit 0100001011000000

move_to_sr:
    need REG, src
    emit 0100011011000000

move_from_sr:
    need REG, dst
    emit 0100000011000000

move_usp_to_a:
    need REG, an
    emit 0100111001101000

move_a_to_usp:
    need REG, an
    emit 0100111001100000

; ============================================================
; Bit manipulation
; ============================================================

btst_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0000100000000000
    emit _imm8

bset_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0000100010000000
    emit _imm8

bclr_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0000100001000000
    emit _imm8

bchg_imm_d:
    need VALUE, imm
    need REG, dst
    bitfit imm.binary, 8
    zext _imm8, imm.binary, 8
    emit 0000100001000000
    emit _imm8

btst_d_d:
    need REG, src
    need REG, dst
    emit 0000000100000000

bset_d_d:
    need REG, src
    need REG, dst
    emit 0000000110000000

bclr_d_d:
    need REG, src
    need REG, dst
    emit 0000000101000000

bchg_d_d:
    need REG, src
    need REG, dst
    emit 0000000101000000

; ============================================================
; Scc - Set on condition
; ============================================================

scc_t_d:
    need REG, dst
    emit 0101000011000000

scc_f_d:
    need REG, dst
    emit 0101000111000000

scc_hi_d:
    need REG, dst
    emit 0101001011000000

scc_ls_d:
    need REG, dst
    emit 0101001111000000

scc_cc_d:
    need REG, dst
    emit 0101010011000000

scc_cs_d:
    need REG, dst
    emit 0101010111000000

scc_ne_d:
    need REG, dst
    emit 0101011011000000

scc_eq_d:
    need REG, dst
    emit 0101011111000000

scc_vc_d:
    need REG, dst
    emit 0101100011000000

scc_vs_d:
    need REG, dst
    emit 0101100111000000

scc_pl_d:
    need REG, dst
    emit 0101101011000000

scc_mi_d:
    need REG, dst
    emit 0101101111000000

scc_ge_d:
    need REG, dst
    emit 0101110011000000

scc_lt_d:
    need REG, dst
    emit 0101110111000000

scc_gt_d:
    need REG, dst
    emit 0101111011000000

scc_le_d:
    need REG, dst
    emit 0101111111000000

; ============================================================
; BCD arithmetic
; ============================================================

abcd_d_d:
    need REG, src
    need REG, dst
    emit 1100000100000000

sbcd_d_d:
    need REG, src
    need REG, dst
    emit 1000000100000000

nbcd:
    need REG, dst
    emit 0100100000000000

; ============================================================
; VDP helpers (Sega Genesis specific)
; ============================================================

vdp_write_w:
    need VALUE, data
    need VALUE, addr
    bitfit data.binary, 16
    zext _data16, data.binary, 16
    bitfit addr.binary, 32
    zext _addr32, addr.binary, 32
    emit 0011001110111001
    emit _data16
    emit _addr32

vdp_ctrl_w:
    need VALUE, cmd
    bitfit cmd.binary, 32
    zext _cmd32, cmd.binary, 32
    emit 0010001110111001
    emit _cmd32
    emit 110000000000000000000100

; ============================================================
; ROM padding + vectors (Sega Genesis header)
; ============================================================

md_vectors:
    need LABEL, target
    md_vectors target

md_header:
    md_header

md_rompad:
    md_pad_to 16384
