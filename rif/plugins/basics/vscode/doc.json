{
  "words": {
    "rif_project": {
      "doc": [
        {
          "type": "text",
          "content": "RIF separa arquitectura, herramientas y proyecto. El pack declara plugins; el proyecto declara codigo y assets."
        },
        {
          "type": "code",
          "content": ".pack\nplugin \"basics\"\nplugin \"gba\""
        }
      ]
    },
    "need": {
      "doc": [
        {
          "type": "text",
          "content": "Consume y valida operandos de una regla usando tipos RIF."
        },
        {
          "type": "code",
          "content": "need VALUE, imm"
        }
      ]
    },
    "switch": {
      "doc": [
        {
          "type": "text",
          "content": "Define caminos de generacion condicional dentro de una regla."
        },
        {
          "type": "code",
          "content": "switch mode:\n    case fast:\n        emit 0001"
        }
      ]
    },
    "emit": {
      "doc": [
        {
          "type": "text",
          "content": "Emite bits o placeholders ya capturados por la regla actual."
        },
        {
          "type": "code",
          "content": "emit imm.binary"
        }
      ]
    },
    "align": {
      "doc": [
        {
          "type": "text",
          "content": "Alinea el bloque binario actual a un multiplo de bytes."
        },
        {
          "type": "code",
          "content": "align 4"
        }
      ]
    },
    "pad": {
      "doc": [
        {
          "type": "text",
          "content": "Rellena con bytes hasta alcanzar un offset fisico."
        },
        {
          "type": "code",
          "content": "pad 0x100 00"
        }
      ]
    },
    "reloc": {
      "doc": [
        {
          "type": "text",
          "content": "Registra una relocacion absoluta o fisica que el linker resuelve al final."
        },
        {
          "type": "code",
          "content": "reloc abs, target, 32"
        }
      ]
    },
    "reldis": {
      "doc": [
        {
          "type": "text",
          "content": "Registra un desplazamiento relativo entre una posicion de origen y una etiqueta destino."
        },
        {
          "type": "code",
          "content": "reldis ., target, 8"
        }
      ]
    },
    "fillid": {
      "doc": [
        {
          "type": "text",
          "content": "Emite la direccion fisica de un asset registrado en fills.json."
        }
      ]
    },
    "vfillid": {
      "doc": [
        {
          "type": "text",
          "content": "Emite la direccion virtual de un asset registrado en fills.json."
        }
      ]
    }
  }
}
