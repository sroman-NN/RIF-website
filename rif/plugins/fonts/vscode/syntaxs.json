      "match": "@(?:fonts_fill_text_u8|fonts_fill_text_u16|fonts_fill_text_u32|fonts_fill_[3456]x[5678]x1|bitmap_array_logo)\\b"
    },
    {
      "name": "support.constant.fonts.file",
      "match": "\\b(?:font-[3456]x[5678]x1\\.f|3x5|4x6|5x7|6x8|3x5x1|4x6x1|5x7x1|6x8x1)\\b"
    }
  ],
  "errors": [
    {
      "match": "@\\s*fonts_fill_",
      "message": "Fonts: usa la forma @\"Texto\" [fuente]@fillable@label.",
      "severity": "warning",
      "code": "fonts-reverse-fillable",
      "suggest": "Ejemplo: @\"Texto\" 5x7@fonts_fill_text_u16@texto_bitmap"
    },
    {
      "match": "@\"\"@fonts_fill_",
      "message": "Fonts: el texto vacio genera un asset sin glyphs visibles.",
      "severity": "hint",
      "code": "fonts-empty-text"
    }
  ]
