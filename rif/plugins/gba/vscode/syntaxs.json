  "completions": [
    {
      "label": "gba_rom_skeleton",
      "insertText": ".header\n    set_headers\n    set_logo\n    set_checksum \"${1:RIF GBA}\"\n    set_entry\n\n.rom\nmain:\n    ${2:arm_b main}\n\n.rodata\n    rompad",
      "detail": "GBA project",
      "documentation": "Plantilla minima de ROM GBA con header, entrada ARM y padding final.",
      "kind": "Snippet",
      "sortText": "000-gba-rom-skeleton"
    },
    {
      "label": "gba_mode3_red",
      "insertText": ".header\n    set_headers\n    set_logo\n    set_checksum \"${1:RIF GBA}\"\n    set_entry\n\n.rom\nmain:\n    arm_mov_imm R0, 0x04000000\n    arm_mov_imm R1, 0x0400\n    arm_add_imm R1, R1, 0x03\n    arm_strh R1, R0, 0\n\n    arm_mov_imm R2, 0x06000000\n    arm_mov_imm R3, 0x06000000\n    arm_add_imm R3, R3, 0x12C00\n    arm_mov_imm R4, 0x001F\nfill_loop:\n    arm_strh R4, R2, 0\n    arm_add_imm R2, R2, 2\n    arm_cmp R2, R3\n    arm_bcond ne, fill_loop\nforever:\n    arm_b forever\n\n.rodata\n    rompad",
      "detail": "GBA Mode 3",
      "documentation": "ROM minima que activa Mode 3 y pinta la pantalla en rojo BGR555.",
      "kind": "Snippet",
      "sortText": "001-gba-mode3-red"
    },
    {
      "label": "store",
      "insertText": "store ${1:R0} = ${2:0}",
      "detail": "GBA Thumb",
      "documentation": "MOV inmediato de 8 bits."
    },
    {
      "label": "movs",
      "insertText": "movs ${1:R0} ${2:0}",
      "detail": "ARM7TDMI Thumb",
      "documentation": "MOVS Rd, #imm8. Forma canonica Thumb para cargar un inmediato en R0-R7.",
      "kind": "Snippet",
      "sortText": "010-thumb-movs"
    },
    {
      "label": "adds",
      "insertText": "adds ${1:R0} ${2:R1} ${3:R2}",
      "detail": "ARM7TDMI Thumb",
      "documentation": "ADDS Rd, Rs, Rn. Suma de registros bajos Thumb.",
      "kind": "Snippet",
      "sortText": "011-thumb-adds"
    },
    {
      "label": "subs",
      "insertText": "subs ${1:R0} ${2:R1} ${3:R2}",
      "detail": "ARM7TDMI Thumb",
      "documentation": "SUBS Rd, Rs, Rn. Resta de registros bajos Thumb.",
      "kind": "Snippet",
      "sortText": "012-thumb-subs"
    },
    {
      "label": "strh",
      "insertText": "strh ${1:R0}, ${2:R1}, ${3:0}",
      "detail": "GBA Thumb",
      "documentation": "Guarda 16 bits en memoria."
    },
    {
      "label": "push_list",
      "insertText": "push ${1:{R0-R3,LR}}",
      "detail": "ARM7TDMI Thumb",
      "documentation": "PUSH {Rlist, LR}. Sintaxis de lista real para stack Thumb.",
      "kind": "Snippet",
      "sortText": "013-thumb-push"
    },
    {
      "label": "pop_list",
      "insertText": "pop ${1:{R0-R3,PC}}",
      "detail": "ARM7TDMI Thumb",
      "documentation": "POP {Rlist, PC}. Sintaxis de lista real para retorno Thumb.",
      "kind": "Snippet",
      "sortText": "014-thumb-pop"
    },
    {
      "label": "arm_ldr_label",
      "insertText": "arm_ldr_label ${1:R0}, ${2:label}",
      "detail": "GBA ARM",
      "documentation": "Carga la direccion de una etiqueta."
    },
    {
      "label": "arm_beq",
      "insertText": "arm_beq ${1:label}",
      "detail": "ARM7TDMI ARM",
      "documentation": "Branch ARM condicional BEQ. Alias de arm_b con condicion eq.",
      "kind": "Snippet",
      "sortText": "020-arm-beq"
    },
    {
      "label": "arm_bne",
      "insertText": "arm_bne ${1:label}",
      "detail": "ARM7TDMI ARM",
      "documentation": "Branch ARM condicional BNE. Alias de arm_b con condicion ne.",
      "kind": "Snippet",
      "sortText": "021-arm-bne"
    },
    {
      "label": "apply_reloc",
      "insertText": "apply_reloc ${1:abs}, ${2:label}, ${3:32}",
      "detail": "GBA linker",
      "documentation": "Emite una relocacion."
    },
    {
      "label": "vram_base",
      "insertText": "arm_mov_imm ${1:R0}, 0x06000000",
      "detail": "GBA memory",
      "documentation": "Carga la base de VRAM en un registro ARM.",
      "kind": "Snippet"
    },
    {
      "label": "wait_vblank",
      "insertText": "wait_vblank:\n    arm_mov_imm R0, 0x04000000\n    arm_add_imm R0, R0, 0x06\nwait_vblank_loop:\n    arm_ldrh R1, R0, 0\n    arm_cmp_imm R1, 160\n    arm_bcond lt, wait_vblank_loop",
      "detail": "GBA video",
      "documentation": "Snippet de espera de VBlank leyendo VCOUNT.",
      "kind": "Snippet"
    }
  ],
  "patterns": [
    {
      "name": "constant.numeric.address.gba",
      "match": "\\b0x0(?:2|3|4|5|6|7|8)[0-9A-Fa-f]{6}\\b"
    },
    {
      "name": "support.constant.gba.io",
      "match": "\\b(?:DISPCNT|DISPSTAT|VCOUNT|KEYINPUT|KEYCNT|SOUNDCNT_H|SOUNDCNT_X|FIFO_A|FIFO_B|DMA[0-3](?:SAD|DAD|CNT)|TM[0-3]CNT|IE|IF|IME|WAITCNT)\\b"
    },
    {
      "name": "support.constant.gba.memory",
      "match": "\\b(?:BIOS|EWRAM|IWRAM|IOREG|PALRAM|VRAM|OAM|ROM_WS0|ROM_WS1|ROM_WS2|SRAM)\\b"
    },
    {
      "name": "support.constant.gba.key",
      "match": "\\b(?:KEY_A|KEY_B|KEY_SELECT|KEY_START|KEY_RIGHT|KEY_LEFT|KEY_UP|KEY_DOWN|KEY_R|KEY_L)\\b"
    }
  ],
  "errors": [
    {
      "match": "^\\s*\\.text\\b",
      "message": "GBA: el pack oficial usa .rom para codigo ejecutable; .text no esta declarada en gba.sections.pack.",
      "severity": "warning",
      "code": "gba-unknown-text-section",
      "suggest": "Cambiar .text por .rom."
    },
    {
      "match": "\\b(?:add|sub|and|or|xor|mul)\\s+PC\\b",
      "message": "GBA: modificar PC aritmeticamente en Thumb suele romper el flujo. Usa b, jump, bl o bx.",
      "severity": "error"
    },
    {
      "match": "\\bstrb\\b.*0x060[0-9A-Fa-f]{5}",
      "message": "GBA: evita escrituras de 8 bits a VRAM; usa strh para colores/pixeles de 16 bits.",
      "severity": "warning",
      "code": "gba-vram-byte-write",
      "suggest": "Cambiar a strh cuando escribas pixeles o colores en VRAM."
    },
    {
      "match": "\\b(?:arm_mov_imm|mov_imm|store)\\s+R(?:8|9|10|11|12)\\b",
      "message": "GBA Thumb: las formas inmediatas simples normalmente solo aceptan registros bajos R0-R7.",
      "severity": "warning",
      "code": "gba-thumb-low-register"
    },
    {
      "match": "\\b0x060[0-9A-Fa-f]{5}\\b",
      "message": "GBA: direccion en VRAM detectada; recuerda escribir halfwords alineados.",
      "severity": "hint",
      "code": "gba-vram-address"
    }
  ]
}
