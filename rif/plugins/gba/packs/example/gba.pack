comment ;

; ============================================================
; GBA Pack — Archivo raíz del empaquetador
; Usa fsystem 1 para enlazar fragmentos:
;   gba.regs.pack     → sección .regs
;   gba.types.pack    → sección .types
;   gba.sections.pack → sección .sections
;   gba.words.pack    → sección .words
;   gba.rules.pack    → sección .rules
; ============================================================

.pack
plugext ".py"
plugin "gba"
plugin "fonts"
plugin "basics"

packer:
    fsystem 1
    subpre *
    ext ".pack"
    output "hello.gba"
    setpre "regs"     ".regs"
    setpre "types"    ".types"
    setpre "sections" ".sections"
    setpre "words"    ".words"
    setpre "rules"    ".rules"

reader:
    comment ";"
    separator ","
    blocks ":"
    section ".section"
    sources ".rif"
    requiresect true
    validatesect true

types:
    from ".regs" as "REG"

.world
arch "arm7tdmi"
os "gba"
endianness little

.DATA_DEFINITION
arrautofill
index true
