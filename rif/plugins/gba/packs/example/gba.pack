comment ;
blocks :
table-separator |
encoding utf-8

.pack

plugin "basics"
plugin "gba"
plugin "image"
plugin "fonts"
pluginsymbolorder 0

types:
    from ".regs" as REG
    from ".types" as TYPE

packer:
    entryfilename "main"
    ext ".gbasm"
    outext ".gba"
    filesystem 1
    subpre *
    setpre regs .regs
    setpre rules .rules
    setpre sections .sections
    setpre types .types
    setpre words .words

linker:
    filesystem 1
    sectexec .rom
    sectneed .header
    sectneed .data
    sectopt .bss
    sectopt .rodata

reader:
    comment ";"
    separator "|"
    blocks ":"
    section ".section"

.DATA_DEFINITION
    arrautofill true
    supportstring true
