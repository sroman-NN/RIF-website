; =========================
; COMENTARIOS
; =========================
; Esta tabla no usa fila separadora Markdown.
; Todas las filas de datos empiezan con |.
; Los comentarios empiezan con ;.
;
; NAME:
;   Nombre simbolico. Es el unico campo fijo obligatorio.
;
; bits:
;   Tamano en bits. En regiones de memoria es el tamano total de la region.
;
; code:
;   CPU: codigo binario real del registro ARM.
;   MMIO/REGION: direccion base en binario de 32 bits.
;   STATUS: codigo interno estable para CPSR/SPSR.
;
; hex:
;   CPU: valor hexadecimal del codigo.
;   MMIO/REGION: direccion base hexadecimal.
;
; fam:
;   Familia del registro.
;   Los subregistros comparten exactamente la misma familia que su registro padre.
;   Ejemplo: BG2X, BG2X00 y BG2X01 usan fam BG2X.
;
; part:
;   0 = entrada principal.
;   1 = parte baja de 16 bits.
;   2 = parte alta de 16 bits.
;   3 = alias simbolico, por ejemplo SP/LR/PC.
;   4 = registro fisico bancarizado.
;
; GNP:
;   yes = registro de proposito general.
;   no = registro especial, MMIO, region, alias o estado.
;
; ARM:
;   yes = accesible desde ARM o pertenece al estado ARM7TDMI/GBA.
;   no = no accesible.
;
; THUMB:
;   yes = usable desde THUMB por acceso directo, especial o por load/store a memoria.
;   no = no usable directamente desde THUMB.
;
; TLOW:
;   yes = registro bajo THUMB R0-R7.
;   no = no es registro bajo THUMB.
;
; THIGH:
;   yes = registro alto THUMB R8-R12 para operaciones high-register.
;   no = no es registro alto THUMB normal.
;
; TSP:
;   yes = registro especial SP en THUMB.
;   no = no es SP.
;
; TLR:
;   yes = registro especial LR en THUMB.
;   no = no es LR.
;
; TPC:
;   yes = registro especial PC en THUMB.
;   no = no es PC.
;
; MMIO:
;   yes = registro de hardware mapeado en 0x04000000+.
;   no = no es MMIO.
;
; REGION:
;   yes = region de memoria.
;   no = registro individual o alias.
;
; BANKED:
;   yes = registro fisico bancarizado por modo CPU.
;   no = registro no bancarizado.
;
; ALIAS:
;   yes = nombre alternativo o subparte de otro registro.
;   no = entrada principal.
;
; =========================
; type 0-n
; =========================
; type 0  = CPU_GPR
;   Registros visibles principales del ARM7TDMI: R0-R15 y alias SP/LR/PC.
;
; type 1  = VIDEO_VRAM_PPU
;   Video, LCD, fondos, ventanas, blending, PALRAM, VRAM y OAM.
;
; type 2  = SOUND
;   Registros PSG, Direct Sound, Wave RAM, FIFO A/B y control de audio.
;
; type 3  = DMA
;   Canales DMA0-DMA3: source, destination, count/control.
;
; type 4  = TIMER
;   Timers TM0-TM3.
;
; type 5  = INPUT
;   Botones: KEYINPUT y KEYCNT.
;
; type 6  = SERIAL
;   Link cable, SIO normal/multiplayer/UART/general purpose y joy bus.
;
; type 7  = INTERRUPT
;   IE, IF e IME.
;
; type 8  = SYSTEM
;   WAITCNT, POSTFLG y HALTCNT.
;
; type 9  = STATUS
;   CPSR y SPSR.
;
; type 10 = BANKED
;   Registros fisicos bancarizados por modo CPU: FIQ, IRQ, SVC, ABT y UND.
;
; type 11 = MEMORY_REGION
;   Regiones principales del mapa de memoria: BIOS, WRAM, IOREG, ROM y SRAM.
;
